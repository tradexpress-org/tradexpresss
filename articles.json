document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('tx-search-input');
    const suggestionsBox = document.getElementById('suggestions-box');
    
    if (!searchInput || !suggestionsBox) return;

    let searchDatabase = [];

    // 1. Fetch JSON and build a flat suggestion database (Titles, Agencies, HS Codes, and Tags)
    fetch('./articles.json')
        .then(res => res.json())
        .then(articles => {
            const tempSet = new Set();
            
            articles.forEach(article => {
                if (article.title) tempSet.add({ text: article.title, type: 'Topic', id: article.id });
                if (article.agency) tempSet.add({ text: article.agency, type: 'Agency', id: article.id });
                if (article.hs && article.hs !== "N/A") tempSet.add({ text: `HS Code ${article.hs}`, type: 'HS Code', id: article.id });
                if (article.tags) {
                    article.tags.forEach(tag => tempSet.add({ text: tag, type: 'Tag', id: article.id }));
                }
            });
            
            searchDatabase = Array.from(tempSet);
        })
        .catch(err => console.error("Error initializing suggestions:", err));

    // 2. Listen to visitor typing
    searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        suggestionsBox.innerHTML = '';
        
        if (query.length < 1) {
            suggestionsBox.style.display = 'none';
            return;
        }

        // Filter database matches
        const matches = searchDatabase.filter(item => 
            item.text.toLowerCase().includes(query)
        ).slice(0, 6); // Limit to top 6 matches

        if (matches.length === 0) {
            suggestionsBox.style.display = 'none';
            return;
        }

        // Render matching suggestion elements
        suggestionsBox.innerHTML = matches.map(match => `
            <div class="suggestion-item" data-id="${match.id}" data-text="${match.text}"
                 style="padding: 10px 15px; cursor: pointer; border-bottom: 1px solid #1e293b; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; color: #cbd5e1; transition: background 0.15s;">
                <span>${match.text}</span>
                <span style="font-size: 0.7rem; color: #38bdf8; background: #0c4a6e; padding: 2px 6px; border-radius: 4px;">${match.type}</span>
            </div>
        `).join('');

        suggestionsBox.style.display = 'block';
    });

    // Hover design & Selection events
    suggestionsBox.addEventListener('mouseover', (e) => {
        const item = e.target.closest('.suggestion-item');
        if (item) item.style.background = '#1e293b';
    });
    
    suggestionsBox.addEventListener('mouseout', (e) => {
        const item = e.target.closest('.suggestion-item');
        if (item) item.style.background = 'transparent';
    });

    suggestionsBox.addEventListener('click', (e) => {
        const item = e.target.closest('.suggestion-item');
        if (item) {
            const targetText = item.getAttribute('data-text');
            const targetId = item.getAttribute('data-id');
            
            searchInput.value = targetText;
            suggestionsBox.style.display = 'none';
            
            // Auto scroll directly to the matching article card on the page
            const targetCard = document.getElementById(targetId);
            if (targetCard) {
                targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                targetCard.style.outline = '2px solid #38bdf8';
                setTimeout(() => targetCard.style.outline = 'none', 2000);
            }
        }
    });

    // Close suggestions box if visitor clicks outside
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.search-container')) {
            suggestionsBox.style.display = 'none';
        }
    });
});